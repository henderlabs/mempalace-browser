# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# python
__pycache__/
*.py[cod]
*$py.class
.Python
build/
dist/
*.egg-info/

# environments
.venv/
venv/
env/

# secrets — belt and braces. Nothing here should ever exist in this repo,
# and if it does, it should not be the commit that finds out.
.env
.env.*
*.pem
*.key
*.p12
*.pfx
*.token
*credentials*
*secrets*
id_rsa
id_ed25519

# local dumps / scratch
*.log
*.sqlite3
*.db
*.dump
_check.mjs

# editors
.vscode/
.idea/
*.swp
.DS_Store
